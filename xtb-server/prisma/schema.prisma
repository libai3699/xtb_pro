generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id         BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  username   String      @unique(map: "username") @db.VarChar(50)
  password   String      @db.VarChar(255)
  name       String      @db.VarChar(50)
  mobile     String?     @db.VarChar(20)
  role       String      @default("admin") @db.VarChar(30)
  status     Int         @default(1) @db.TinyInt
  createdAt  DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  loginLogs  LoginLog[]  @relation("AdminUserLoginLogs")

  @@map("admin_user")
}

model AppUser {
  id                 BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  role               String              @db.VarChar(20)
  account            String?             @unique(map: "uk_app_user_account") @db.VarChar(50)
  password           String?             @db.VarChar(255)
  nickname           String?             @db.VarChar(50)
  avatar             String?             @db.VarChar(255)
  mobile             String?             @db.VarChar(20)
  openid             String?             @db.VarChar(100)
  unionid            String?             @db.VarChar(100)
  status             Int                 @default(1) @db.TinyInt
  createdAt          DateTime            @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  agentProfile       AgentProfile?
  agentLeads         Lead[]              @relation("LeadAgentUser")
  studentLeads       Lead[]              @relation("LeadStudentUser")
  agentOrders        Order[]             @relation("OrderAgentUser")
  studentOrders      Order[]             @relation("OrderStudentUser")
  shares             CampaignShare[]
  agentStats         StatsDaily[]        @relation("StatsAgentUser")
  loginLogs          LoginLog[]          @relation("AppUserLoginLogs")
  pointRecords       PointRecord[]
  rewardRedeemOrders RewardRedeemOrder[]
  messages           UserMessage[]
  favorites          UserFavorite[]
  certificates       UserCertificate[]
  learningRecords    LearningRecord[]
  feedbacks          UserFeedback[]
  agentReviews       AgentReview[]       @relation("AgentReviewUser")

  @@index([role], map: "idx_app_user_role")
  @@index([mobile], map: "idx_app_user_mobile")
  @@map("app_user")
}

model AgentProfile {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt   @unique(map: "uk_agent_user_id") @map("user_id") @db.UnsignedBigInt
  realName   String   @map("real_name") @db.VarChar(50)
  schoolName String?  @map("school_name") @db.VarChar(100)
  majorName  String?  @map("major_name") @db.VarChar(100)
  gradeName  String?  @map("grade_name") @db.VarChar(30)
  inviteCode String?  @map("invite_code") @db.VarChar(30)
  status     Int      @default(0) @db.TinyInt
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([status], map: "idx_agent_status")
  @@map("agent_profile")
}

model Campaign {
  id          BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  title       String          @db.VarChar(100)
  campaignType String?        @map("campaign_type") @db.VarChar(30)
  targetCount Int?            @map("target_count")
  location    String?         @db.VarChar(120)
  cover       String?         @db.VarChar(255)
  description String?         @db.Text
  requirement String?         @db.Text
  formConfig  Json?           @map("form_config")
  rewardDesc  String?         @map("reward_desc") @db.VarChar(255)
  startTime   DateTime?       @map("start_time") @db.DateTime(0)
  endTime     DateTime?       @map("end_time") @db.DateTime(0)
  status      Int             @default(0) @db.TinyInt
  createdAt   DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  shares      CampaignShare[]
  leads       Lead[]
  products    Product[]
  orders      Order[]
  dailyStats  StatsDaily[]

  @@index([status], map: "idx_campaign_status")
  @@map("campaign")
}

model CampaignShare {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  campaignId  BigInt   @map("campaign_id") @db.UnsignedBigInt
  agentUserId BigInt   @map("agent_user_id") @db.UnsignedBigInt
  shareCode   String   @unique(map: "uk_share_code") @map("share_code") @db.VarChar(50)
  shareUrl    String?  @map("share_url") @db.VarChar(255)
  pv          Int      @default(0)
  uv          Int      @default(0)
  leadCount   Int      @default(0) @map("lead_count")
  orderCount  Int      @default(0) @map("order_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  agentUser   AppUser  @relation(fields: [agentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([campaignId], map: "idx_campaign_share_campaign")
  @@index([agentUserId], map: "idx_campaign_share_agent")
  @@map("campaign_share")
}

model Lead {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  campaignId    BigInt    @map("campaign_id") @db.UnsignedBigInt
  agentUserId   BigInt?   @map("agent_user_id") @db.UnsignedBigInt
  studentUserId BigInt?   @map("student_user_id") @db.UnsignedBigInt
  name          String    @db.VarChar(50)
  mobile        String    @db.VarChar(20)
  schoolName    String?   @map("school_name") @db.VarChar(100)
  majorName     String?   @map("major_name") @db.VarChar(100)
  gradeName     String?   @map("grade_name") @db.VarChar(30)
  remark        String?   @db.VarChar(255)
  status        Int       @default(0) @db.TinyInt
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  agentUser     AppUser?  @relation("LeadAgentUser", fields: [agentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  studentUser   AppUser?  @relation("LeadStudentUser", fields: [studentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([campaignId], map: "idx_lead_campaign")
  @@index([agentUserId], map: "idx_lead_agent")
  @@index([mobile], map: "idx_lead_mobile")
  @@map("lead")
}

model Product {
  id              BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  campaignId      BigInt           @map("campaign_id") @db.UnsignedBigInt
  title           String           @db.VarChar(100)
  price           Decimal          @default(0.00) @db.Decimal(10, 2)
  originalPrice   Decimal?         @map("original_price") @db.Decimal(10, 2)
  cover           String?          @db.VarChar(255)
  description     String?          @db.Text
  status          Int              @default(1) @db.TinyInt
  createdAt       DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  orders          Order[]
  learningRecords LearningRecord[]
  certificates    UserCertificate[]

  @@index([campaignId], map: "idx_product_campaign")
  @@index([status], map: "idx_product_status")
  @@map("product")
}

model Order {
  id            BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  orderNo       String          @unique(map: "uk_order_no") @map("order_no") @db.VarChar(50)
  productId     BigInt          @map("product_id") @db.UnsignedBigInt
  campaignId    BigInt?         @map("campaign_id") @db.UnsignedBigInt
  agentUserId   BigInt?         @map("agent_user_id") @db.UnsignedBigInt
  studentUserId BigInt?         @map("student_user_id") @db.UnsignedBigInt
  studentName   String          @map("student_name") @db.VarChar(50)
  mobile        String          @db.VarChar(20)
  amount        Decimal         @default(0.00) @db.Decimal(10, 2)
  status        Int             @default(0) @db.TinyInt
  payTime       DateTime?       @map("pay_time") @db.DateTime(0)
  createdAt     DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  campaign      Campaign?       @relation(fields: [campaignId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  agentUser     AppUser?        @relation("OrderAgentUser", fields: [agentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  studentUser   AppUser?        @relation("OrderStudentUser", fields: [studentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  payments      PaymentRecord[]

  @@index([productId], map: "idx_orders_product")
  @@index([campaignId], map: "idx_orders_campaign")
  @@index([agentUserId], map: "idx_orders_agent")
  @@index([studentUserId], map: "idx_orders_student")
  @@map("orders")
}

model PaymentRecord {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  orderId       BigInt   @map("order_id") @db.UnsignedBigInt
  orderNo       String   @map("order_no") @db.VarChar(50)
  payChannel    String   @default("wechat") @map("pay_channel") @db.VarChar(20)
  transactionId String?  @map("transaction_id") @db.VarChar(100)
  amount        Decimal  @default(0.00) @db.Decimal(10, 2)
  status        Int      @default(0) @db.TinyInt
  rawCallback   String?  @map("raw_callback") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([orderId], map: "idx_payment_order_id")
  @@index([orderNo], map: "idx_payment_order_no")
  @@map("payment_record")
}

model StatsDaily {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  statDate    DateTime  @map("stat_date") @db.Date
  campaignId  BigInt?   @map("campaign_id") @db.UnsignedBigInt
  agentUserId BigInt?   @map("agent_user_id") @db.UnsignedBigInt
  pv          Int       @default(0)
  uv          Int       @default(0)
  leadCount   Int       @default(0) @map("lead_count")
  orderCount  Int       @default(0) @map("order_count")
  paidAmount  Decimal   @default(0.00) @map("paid_amount") @db.Decimal(10, 2)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  agentUser   AppUser?  @relation("StatsAgentUser", fields: [agentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([statDate, campaignId, agentUserId], map: "uk_stats_daily")
  @@map("stats_daily")
}

model LoginLog {
  id          BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  loginType   String     @map("login_type") @db.VarChar(20)
  adminUserId BigInt?    @map("admin_user_id") @db.UnsignedBigInt
  appUserId   BigInt?    @map("app_user_id") @db.UnsignedBigInt
  username    String?    @db.VarChar(50)
  role        String?    @db.VarChar(30)
  loginStatus Int        @default(1) @map("login_status") @db.TinyInt
  ip          String?    @db.VarChar(64)
  countryName String?    @map("country_name") @db.VarChar(100)
  regionName  String?    @map("region_name") @db.VarChar(100)
  cityName    String?    @map("city_name") @db.VarChar(100)
  orgName     String?    @map("org_name") @db.VarChar(150)
  locationText String?   @map("location_text") @db.VarChar(255)
  userAgent   String?    @map("user_agent") @db.VarChar(500)
  message     String?    @db.VarChar(255)
  loginAt     DateTime   @default(now()) @map("login_at") @db.DateTime(0)
  createdAt   DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  adminUser   AdminUser? @relation("AdminUserLoginLogs", fields: [adminUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  appUser     AppUser?   @relation("AppUserLoginLogs", fields: [appUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([loginType], map: "idx_login_log_type")
  @@index([adminUserId], map: "idx_login_log_admin_user")
  @@index([appUserId], map: "idx_login_log_app_user")
  @@index([loginAt], map: "idx_login_log_login_at")
  @@map("login_log")
}

model ContentArticle {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  type        String   @db.VarChar(20)
  title       String   @db.VarChar(120)
  summary     String?  @db.VarChar(255)
  cover       String?  @db.VarChar(255)
  category    String?  @db.VarChar(50)
  content     String?  @db.Text
  sort        Int      @default(0)
  status      Int      @default(1) @db.TinyInt
  publishedAt DateTime? @map("published_at") @db.DateTime(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)

  @@index([type, status], map: "idx_content_article_type_status")
  @@map("content_article")
}

model UserMessage {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  type      String   @default("system") @db.VarChar(20)
  title     String   @db.VarChar(120)
  content   String   @db.VarChar(500)
  bizType   String?  @map("biz_type") @db.VarChar(30)
  bizId     BigInt?  @map("biz_id") @db.UnsignedBigInt
  isRead    Int      @default(0) @map("is_read") @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, isRead], map: "idx_user_message_user_read")
  @@map("user_message")
}

model RewardGoods {
  id          BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  title       String              @db.VarChar(120)
  cover       String?             @db.VarChar(255)
  points      Int                 @default(0)
  stock       Int                 @default(0)
  description String?             @db.Text
  sort        Int                 @default(0)
  status      Int                 @default(1) @db.TinyInt
  createdAt   DateTime            @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  redeemOrders RewardRedeemOrder[]

  @@index([status, sort], map: "idx_reward_goods_status_sort")
  @@map("reward_goods")
}

model RewardRedeemOrder {
  id        BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  orderNo   String      @unique(map: "uk_reward_redeem_order_no") @map("order_no") @db.VarChar(50)
  userId    BigInt      @map("user_id") @db.UnsignedBigInt
  goodsId   BigInt      @map("goods_id") @db.UnsignedBigInt
  points    Int         @default(0)
  status    Int         @default(0) @db.TinyInt
  createdAt DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user      AppUser     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  goods     RewardGoods @relation(fields: [goodsId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId], map: "idx_reward_redeem_order_user")
  @@index([goodsId], map: "idx_reward_redeem_order_goods")
  @@map("reward_redeem_order")
}

model PointRecord {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId       BigInt   @map("user_id") @db.UnsignedBigInt
  type         String   @db.VarChar(20)
  changeValue  Int      @map("change_value")
  balanceValue Int      @default(0) @map("balance_value")
  remark       String?  @db.VarChar(255)
  bizType      String?  @map("biz_type") @db.VarChar(30)
  bizId        BigInt?  @map("biz_id") @db.UnsignedBigInt
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  user         AppUser  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, createdAt], map: "idx_point_record_user_created")
  @@map("point_record")
}

model UserFavorite {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt   @map("user_id") @db.UnsignedBigInt
  targetType  String   @map("target_type") @db.VarChar(20)
  targetId    BigInt   @map("target_id") @db.UnsignedBigInt
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([userId, targetType, targetId], map: "uk_user_favorite")
  @@index([userId, createdAt], map: "idx_user_favorite_user_created")
  @@map("user_favorite")
}

model UserCertificate {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt    @map("user_id") @db.UnsignedBigInt
  productId   BigInt?   @map("product_id") @db.UnsignedBigInt
  title       String    @db.VarChar(120)
  issuer      String?   @db.VarChar(120)
  cover       String?   @db.VarChar(255)
  fileUrl     String?   @map("file_url") @db.VarChar(255)
  issuedAt    DateTime? @map("issued_at") @db.DateTime(0)
  status      Int       @default(1) @db.TinyInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user        AppUser   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, status], map: "idx_user_certificate_user_status")
  @@map("user_certificate")
}

model LearningRecord {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId          BigInt    @map("user_id") @db.UnsignedBigInt
  productId       BigInt?   @map("product_id") @db.UnsignedBigInt
  title           String    @db.VarChar(120)
  cover           String?   @db.VarChar(255)
  progress        Int       @default(0)
  durationMinutes Int       @default(0) @map("duration_minutes")
  lastStudyAt     DateTime? @map("last_study_at") @db.DateTime(0)
  status          Int       @default(1) @db.TinyInt
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user            AppUser   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId, status], map: "idx_learning_record_user_status")
  @@map("learning_record")
}

model UserFeedback {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt?  @map("user_id") @db.UnsignedBigInt
  type       String   @default("suggestion") @db.VarChar(20)
  content    String   @db.VarChar(1000)
  contact    String?  @db.VarChar(100)
  status     Int      @default(0) @db.TinyInt
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  user       AppUser? @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([status, createdAt], map: "idx_user_feedback_status_created")
  @@map("user_feedback")
}

model AgentReview {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  agentUserId BigInt   @map("agent_user_id") @db.UnsignedBigInt
  score       Int      @default(5) @db.TinyInt
  content     String?  @db.VarChar(255)
  status      Int      @default(1) @db.TinyInt
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(0)
  agentUser   AppUser  @relation("AgentReviewUser", fields: [agentUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([agentUserId, status], map: "idx_agent_review_user_status")
  @@map("agent_review")
}
